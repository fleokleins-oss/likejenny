# ═══════════════ APEX CITADEL v3 — .env.example ═══════════════

# ──── Exchange API Keys ────
BINANCE_API_KEY=changeme
BINANCE_API_SECRET=changeme
BYBIT_API_KEY=changeme
BYBIT_API_SECRET=changeme
OKX_API_KEY=changeme
OKX_API_SECRET=changeme
OKX_PASSWORD=changeme
USE_TESTNET=TRUE

# ──── Master Orchestrator v3 (8007) ────
MAESTRO_V3_CONFLUENCE_MODE=MAJORITY
MAESTRO_V3_MIN_CONFIDENCE=0.55
MAESTRO_V3_PARALLEL_TIMEOUT_S=6.0
MAESTRO_V3_ATR_PERIOD=14
MAESTRO_V3_MAX_NOTIONAL_USD=50000
MAESTRO_V3_REQUIRED_NODES=
MAESTRO_V3_FALLBACK_ON_TIMEOUT=WAIT
MAESTRO_V3_ADMIN_TOKEN=changeme
MAESTRO_V3_BASE_RISK_PCT=0.01
MAESTRO_V3_TARGET_RISK_USD=500.0

# Circuit breaker
MAESTRO_V3_CB_FAILURE_THRESHOLD=5
MAESTRO_V3_CB_COOLDOWN_S=60.0
MAESTRO_V3_CB_PROBE_INTERVAL_S=15.0

# Node weights (JSON, optional)
# MAESTRO_V3_NODE_WEIGHTS={"brain":1.5,"spoofhunter":1.2,"newtonian":1.0}

# ──── Upstream Node URLs ────
MAESTRO_BRAIN_URL=http://127.0.0.1:8000
MAESTRO_SHADOW_URL=http://127.0.0.1:8001
MAESTRO_EXEC_URL=http://127.0.0.1:8002

# v3 nodes (leave empty to disable)
MAESTRO_SPOOFHUNTER_URL=
MAESTRO_NEWTONIAN_URL=
MAESTRO_NARRATIVE_URL=
MAESTRO_DREAMER_URL=
MAESTRO_ANTIRUG_URL=http://127.0.0.1:8003
MAESTRO_ECONOPREDATOR_URL=

# ──── Rate Limiting ────
MAESTRO_TIMEOUT_S=4.0
MAESTRO_ATTEMPTS=4
MAESTRO_RPS_SHADOW=5
MAESTRO_RPS_BRAIN=8
MAESTRO_RPS_EXEC=3

# ──── Redis ────
REDIS_URL=redis://127.0.0.1:6379/0
MAESTRO_QUEUE_STREAM=apex:maestro:jobs
MAESTRO_DLQ_STREAM=apex:maestro:dlq
MAESTRO_QUEUE_GROUP=apex-maestro
MAESTRO_QUEUE_CONSUMER=worker-1
MAESTRO_JOB_TTL_SECONDS=86400
MAESTRO_JOB_MAX_ATTEMPTS=5
MAESTRO_RETRY_BASE_DELAY_S=2
MAESTRO_RETRY_MAX_DELAY_S=120

# ──── Observability ────
METRICS_ENABLED=TRUE
LOG_JSON=FALSE
LOG_LEVEL=INFO
